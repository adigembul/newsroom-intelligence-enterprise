# Newsroom Intelligence Enterprise v6.5
PORT=3000
NODE_ENV=production

# Optional AI Tools / SumoPod compatible endpoint
AI_TOOLS_API_KEY=
SUMOPOD_API_KEY=
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
SUMOPOD_MODEL=gpt-4o-mini

# Optional data APIs
APIFY_TOKEN=
GOOGLE_FACTCHECK_API_KEY=
MAFINDO_API_KEY=

# Performance tuning
REQUEST_TIMEOUT_MS=12000
LIVE_SOURCE_TIMEOUT_MS=7500
LIVE_SEARCH_CACHE_TTL_MS=90000
GDELT_MIN_INTERVAL_MS=6500
GDELT_CACHE_TTL_MS=120000
GDELT_STALE_CACHE_MS=900000

# AI timeout: gunakan nilai besar agar Generate Rilis tidak abort saat model lambat
AI_REQUEST_TIMEOUT_MS=90000
